{
  "name": "playwright-for-typescript",
  "version": "1.0.0",
  "description": "Starter project for learning Playwright with TypeScript",
  "private": true,
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "report": "playwright show-report",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "learn:01": "ts-node examples/typescript-lessons/01-podstawy.ts",
    "learn:02": "ts-node examples/typescript-lessons/02-typy-w-praktyce.ts",
    "learn:03": "ts-node examples/typescript-lessons/03-async-await.ts",
    "learn:04": "ts-node examples/typescript-lessons/04-patterny-testowe.ts",
    "learn:05": "ts-node examples/typescript-lessons/05-sciagawka.ts",
    "learn:06": "ts-node examples/typescript-lessons/06-zmienne-warunki-petle.ts",
    "learn:07": "ts-node examples/typescript-lessons/07-obiekty-tablice-funkcje.ts",
    "learn:08": "ts-node examples/typescript-lessons/08-bledy-try-catch.ts",
    "learn:09": "ts-node examples/typescript-lessons/09-praca-z-api-json.ts",
    "learn:10": "ts-node examples/typescript-lessons/10-playwright-od-zera.ts",
    "learn:all": "npm run learn:01 && npm run learn:02 && npm run learn:03 && npm run learn:04 && npm run learn:05 && npm run learn:06 && npm run learn:07 && npm run learn:08 && npm run learn:09 && npm run learn:10"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arturbardzinski/playwright-for-typescript.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/arturbardzinski/playwright-for-typescript/issues"
  },
  "homepage": "https://github.com/arturbardzinski/playwright-for-typescript#readme",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.5.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2"
  },
  "directories": {
    "doc": "docs",
    "example": "examples",
    "test": "tests"
  }
}
